---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import { projects } from '../data/projects';
---

<Layout>
  <header class="topbar">
    <span class="logo">xaytag</span>
    <input
      class="search"
      type="search"
      placeholder="Search projects…"
      aria-label="Search projects"
      autocomplete="off"
    />
    <div class="meta">
      <span class="greeting" id="greeting"></span>
      <span class="clock" id="clock"></span>
    </div>
  </header>

  <main>
    <section class="grid">
      {projects.map((project) => <Card project={project} />)}
    </section>

    <p class="empty" id="empty" hidden>No projects match your search.</p>

    <footer class="foot">
      <span id="count"
        >{projects.length} project{projects.length === 1 ? '' : 's'}</span
      >
      <span>xaytag.com</span>
    </footer>
  </main>
</Layout>

<script>
  // --- Clock + greeting (local time) ---
  const clock = document.getElementById('clock');
  const greeting = document.getElementById('greeting');

  function tick() {
    const now = new Date();
    if (clock) {
      clock.textContent = now.toLocaleTimeString([], {
        hour: '2-digit',
        minute: '2-digit',
        second: '2-digit',
      });
    }
    if (greeting) {
      const h = now.getHours();
      greeting.textContent =
        h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening';
    }
  }
  tick();
  setInterval(tick, 1000);

  // --- Search / filter ---
  const search = document.querySelector<HTMLInputElement>('.search');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const count = document.getElementById('count');
  const empty = document.getElementById('empty');

  function filter() {
    const q = (search?.value ?? '').trim().toLowerCase();
    let visible = 0;
    for (const card of cards) {
      const match = card.textContent!.toLowerCase().includes(q);
      card.hidden = !match;
      if (match) visible++;
    }
    if (count) count.textContent = `${visible} project${visible === 1 ? '' : 's'}`;
    if (empty) empty.hidden = visible !== 0;
  }
  search?.addEventListener('input', filter);

  // --- Best-effort reachability probe (no-cors; not real monitoring) ---
  function probe(card: HTMLElement) {
    const url = card.dataset.url;
    const dot = card.querySelector<HTMLElement>('.dot');
    if (!url || !dot) return;

    const ctrl = new AbortController();
    const timer = setTimeout(() => ctrl.abort(), 6000);

    fetch(url, { mode: 'no-cors', signal: ctrl.signal })
      .then(() => setStatus(dot, 'online'))
      .catch(() => setStatus(dot, 'offline'))
      .finally(() => clearTimeout(timer));
  }

  function setStatus(dot: HTMLElement, state: 'online' | 'offline') {
    dot.dataset.status = state;
    const label = state === 'online' ? 'Online' : 'Unreachable';
    dot.title = label;
    dot.setAttribute('aria-label', label);
  }

  cards.forEach(probe);
</script>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem clamp(1rem, 4vw, 2rem);
    background: rgba(13, 13, 16, 0.7);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-weight: 700;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    flex: none;
  }

  .search {
    flex: 1;
    min-width: 0;
    max-width: 420px;
    margin: 0 auto;
    padding: 0.5rem 0.9rem;
    font: inherit;
    font-size: 0.9rem;
    color: var(--text);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 999px;
    outline: none;
    transition: border-color 0.15s ease;
  }

  .search:focus {
    border-color: var(--border-hover);
  }

  .search::placeholder {
    color: var(--text-dim);
  }

  .meta {
    flex: none;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    color: var(--text-dim);
    font-size: 0.85rem;
  }

  .clock {
    font-variant-numeric: tabular-nums;
    color: var(--text);
  }

  @media (max-width: 560px) {
    .greeting {
      display: none;
    }
    .search {
      margin: 0 0 0 auto;
    }
  }

  main {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 2.5rem) clamp(1rem, 4vw, 2rem) 3rem;
  }

  .empty {
    color: var(--text-dim);
    text-align: center;
    padding: 2rem 0;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
  }

  .foot {
    display: flex;
    justify-content: space-between;
    margin-top: 2.5rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--border);
    color: var(--text-dim);
    font-size: 0.8rem;
  }
</style>
